# Copy this file to .env and edit values as needed.
FMP_API_KEY=your_fmp_key_here

# Optional SEC fallback settings. Use your real email in production.
SEC_USER_AGENT=DeepValueScreener/1.0 contact@example.com

# Screening thresholds.
MIN_MARKET_CAP=100000000
MAX_MARKET_CAP_TO_NCA=2.0

# Leave blank for the full eligible universe. Useful while testing a free API tier.
MAX_TICKERS=

# Cache and output behavior.
CACHE_TTL_HOURS=720
OUTPUT_DIR=output
CACHE_DIR=cache
LOG_DIR=logs
DATA_DIR=data

# Optional SMTP email report. Set EMAIL_ENABLED=true to send after manual runs.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
SMTP_USE_TLS=true
